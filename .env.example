# Webhook listener
PORT=4000
WEBHOOK_SECRET=change-me   # shared secret PPDM/NW sends in X-Webhook-Secret header

# Alert destinations — set at least one
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...

# Severity thresholds (optional — defaults shown)
ALERT_FAILED_JOBS=true       # alert on any failed job
ALERT_SLA_BREACH=true        # alert when an asset misses its backup window
ALERT_STORAGE_PCT=85         # alert when DD capacity exceeds this %

# SLA poller (proactive — runs on a schedule)
SLA_POLL_INTERVAL_MINS=60    # how often to check SLA compliance (default 60)
SLA_WINDOW_HOURS=24          # assets must have a backup within this window (default 24)
